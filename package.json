    "uuid": "9.0.0",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "chai": "4.4.1",
    "eslint": "8.56.0",
    "mocha": "10.3.0",
    "mongodb-memory-server": "9.1.6",
    "nyc": "15.1.0",
    "supertest": "6.3.4"
